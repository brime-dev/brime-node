{
  "name": "@brime-ai/brime",
  "version": "0.2.0",
  "description": "Official Node.js / TypeScript SDK for the Brime API (search · extract · research)",
  "license": "MIT",
  "author": "Brime",
  "homepage": "https://brime.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brime-dev/brime-node.git"
  },
  "bugs": {
    "url": "https://github.com/brime-dev/brime-node/issues"
  },
  "keywords": [
    "brime",
    "search",
    "extract",
    "research",
    "rag",
    "llm",
    "agents",
    "ai",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*.cjs",
    "dist/**/*.mjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.cts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:live": "vitest run tests/e2e",
    "lint:types": "attw --pack .",
    "lint:publish": "publint",
    "lint:pkg": "npm run lint:publish",
    "prepublishOnly": "npm run build && npm run lint:pkg"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/node": "~20.11.0",
    "publint": "^0.3.0",
    "tsup": "~8.3.0",
    "typescript": "~5.5.0",
    "vitest": "~2.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
